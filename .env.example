# ── Firebase (backend) ─────────────────────────────────────────
# Path to your Firebase service account key JSON file
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_KEY=path/to/serviceAccountKey.json

# ── LLM API Keys (shared across all users) ────────────────────
# These are read by the backend; users don't need to configure them in the UI
OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# MISTRAL_API_KEY=
# DEEPSEEK_API_KEY=
# GROQ_API_KEY=
